+
+# Create remote CAPI cluster using KubeVirt (CAPK) as infrastructure provider.
+# The control plane is exposed via a MetalLB LoadBalancer Service; CAPI discovers
+# the assigned IP automatically so no manual NodePort patching is needed.
+function create_capi_kubevirt_cluster() {
+  local CLUSTER_KUSTOMIZATION_NAME="${1}"
+  local CLUSTER_NAME="${2}"
+  local WORKER_MACHINE_COUNT="${3}"
+  local CONTROL_PLANE_MACHINE_COUNT="${4:-"1"}"
+  local K8S_VERSION="${5}"
+  # Args 6, 7, 8 were kubevirt_host / kubevirt_cp_port / metallb_shared_ip_key under the
+  # old NodePort design. With LoadBalancer type CAPI auto-discovers the endpoint,
+  # so these are accepted but ignored (kept for Argo workflow backward compatibility).
+  local _UNUSED_KUBEVIRT_HOST="${6:-""}"
+  local _UNUSED_KUBEVIRT_CP_PORT="${7:-""}"
+  local _UNUSED_METALLB_SHARED_IP_KEY="${8:-""}"
+  local CONTROL_PLANE_CPU_CORES="${9:-"2"}"
+  local CONTROL_PLANE_MEMORY="${10:-"4Gi"}"
+  local CONTROL_PLANE_EPHEMERAL_STORAGE="${11:-"2Gi"}"
+  local WORKER_CPU_CORES="${12:-"2"}"
+  local WORKER_MEMORY="${13:-"4Gi"}"
+  local WORKER_EPHEMERAL_STORAGE="${14:-"2Gi"}"
+  local VM_IMAGE="${15}"
+  local POD_CIDR="${16:-"10.243.0.0/16"}"
+  local SERVICE_CIDR="${17:-"10.95.0.0/16"}"
+  local CNI="${18:-"calico"}"
+  local PUBLIC_KEY_MGMT="${19:-"${PUBLIC_KEY_MGMT}"}"
+  local PUBLIC_KEY_NEW_CLUSTER="${20}"
+  # arg 21 is intentionally empty; PRIVATE_KEY_NEW_CLUSTER is sourced from env var
+  local FLEET_REPO_DIR="${22:-"${FLEET_REPO_DIR}"}"
+  local FLEET_REPO_URL="${23:-"${FLEET_REPO_URL}"}"
+  local SW_CATALOGS_REPO_DIR="${24:-"${SW_CATALOGS_REPO_DIR}"}"
+  local SW_CATALOGS_REPO_URL="${25:-"${SW_CATALOGS_REPO_URL}"}"
+  local SKIP_BOOTSTRAP="${26:-"false"}"
+  local MGMT_PROJECT_NAME="${27:-"osm_admin"}"
+  local MGMT_CLUSTER_NAME="${28:-"_management"}"
+  local BASE_TEMPLATES_PATH="${29:-"cloud-resources/capi"}"
+  local CAPK_RESOURCES_NAMESPACE="${30:-"default"}"
+
+  # Derived paths
+  local TEMPLATES_DIR="${SW_CATALOGS_REPO_DIR}/${BASE_TEMPLATES_PATH}/kubevirt-kubeadm/templates"
+  local TARGET_FOLDER="${FLEET_REPO_DIR}/${MGMT_PROJECT_NAME}/managed-resources/${MGMT_CLUSTER_NAME}"
+
+  # CAPI creates the kubeconfig secret as "${cluster_name}-kubeconfig" in the CAPI namespace.
+  # The cni and postinstall Kustomizations reference it from the managed-resources namespace
+  # (the copy is performed by a separate Argo step after the cluster becomes Provisioned).
+  export CLUSTER_KUBECONFIG_SECRET_NAME="${CLUSTER_KUSTOMIZATION_NAME}-kubeconfig"
+  export CLUSTER_KUBECONFIG_SECRET_KEY="value"
+  export CLUSTER_KUSTOMIZATION_NAME
+  export CNI="${CNI,,}"
+
+  folder2list \
+    "${TEMPLATES_DIR}" | \
+  replace_env_vars \
+    '${CLUSTER_KUSTOMIZATION_NAME},${CNI},${CLUSTER_KUBECONFIG_SECRET_NAME},${CLUSTER_KUBECONFIG_SECRET_KEY}' | \
+  patch_replace \
+    ".spec.postBuild.substitute.cluster_name" \
+    "${CLUSTER_NAME}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.namespace" \
+    "${CAPK_RESOURCES_NAMESPACE}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.kubernetes_version" \
+    "v${K8S_VERSION}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.control_plane_machine_count" \
+    "${CONTROL_PLANE_MACHINE_COUNT}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.worker_machine_count" \
+    "${WORKER_MACHINE_COUNT}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.control_plane_cpu_cores" \
+    "${CONTROL_PLANE_CPU_CORES}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.control_plane_memory" \
+    "${CONTROL_PLANE_MEMORY}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.control_plane_ephemeral_storage" \
+    "${CONTROL_PLANE_EPHEMERAL_STORAGE}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.worker_cpu_cores" \
+    "${WORKER_CPU_CORES}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.worker_memory" \
+    "${WORKER_MEMORY}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.worker_ephemeral_storage" \
+    "${WORKER_EPHEMERAL_STORAGE}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.vm_image" \
+    "${VM_IMAGE}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.pod_cidr" \
+    "${POD_CIDR}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.service_cidr" \
+    "${SERVICE_CIDR}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.cluster_name" \
+    "${CLUSTER_NAME}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}-cni\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.cluster_name" \
+    "${CLUSTER_NAME}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}-postinstall\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.namespace" \
+    "${CAPK_RESOURCES_NAMESPACE}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}-postinstall\")" | \
+  patch_replace \
+    ".spec.postBuild.substitute.kubernetes_version" \
+    "v${K8S_VERSION}" \
+    "| select(.kind == \"Kustomization\") | select(.metadata.name == \"${CLUSTER_KUSTOMIZATION_NAME}-postinstall\")" | \
+  rename_file_in_items \
+    "capi-cluster-postinstall.yaml" \
+    "postinstall.yaml" | \
+  prepend_folder_path "${CLUSTER_KUSTOMIZATION_NAME}/" | \
+  list2folder_cp_over \
+    "${TARGET_FOLDER}"
+
+  # Bootstrap (unless asked to skip)
+  if [[ "${SKIP_BOOTSTRAP,,}" == "true" ]]; then
+    return 0
+  fi
+
+  create_bootstrap_for_remote_cluster \
+    "${CLUSTER_NAME}" \
+    "${CLUSTER_KUSTOMIZATION_NAME}" \
+    "${FLEET_REPO_DIR}" \
+    "${SW_CATALOGS_REPO_DIR}" \
+    "${FLEET_REPO_URL}" \
+    "${SW_CATALOGS_REPO_URL}" \
+    "${MGMT_PROJECT_NAME}" \
+    "${PUBLIC_KEY_MGMT}" \
+    "${PUBLIC_KEY_NEW_CLUSTER}" \
+    "${PRIVATE_KEY_NEW_CLUSTER}" \
+    "false" \
+    '' \
+    "${CLUSTER_KUBECONFIG_SECRET_NAME}" \
+    "${CLUSTER_KUBECONFIG_SECRET_KEY}"
+}
+
+
+# Update an existing CAPI KubeVirt cluster.
+# Identical to create but always skips bootstrap (avoids duplicate profile/secret creation).
+function update_capi_kubevirt_cluster() {
+  local CLUSTER_KUSTOMIZATION_NAME="${1}"
+  local CLUSTER_NAME="${2}"
+  local WORKER_MACHINE_COUNT="${3}"
+  local CONTROL_PLANE_MACHINE_COUNT="${4:-"1"}"
+  local K8S_VERSION="${5}"
+  local _UNUSED_KUBEVIRT_HOST="${6:-""}"
+  local _UNUSED_KUBEVIRT_CP_PORT="${7:-""}"
+  local _UNUSED_METALLB_SHARED_IP_KEY="${8:-""}"
+  local CONTROL_PLANE_CPU_CORES="${9:-"2"}"
+  local CONTROL_PLANE_MEMORY="${10:-"4Gi"}"
+  local CONTROL_PLANE_EPHEMERAL_STORAGE="${11:-"2Gi"}"
+  local WORKER_CPU_CORES="${12:-"2"}"
+  local WORKER_MEMORY="${13:-"4Gi"}"
+  local WORKER_EPHEMERAL_STORAGE="${14:-"2Gi"}"
+  local VM_IMAGE="${15}"
+  local POD_CIDR="${16:-"10.243.0.0/16"}"
+  local SERVICE_CIDR="${17:-"10.95.0.0/16"}"
+  local CNI="${18:-"calico"}"
+  local PUBLIC_KEY_MGMT="${19:-"${PUBLIC_KEY_MGMT}"}"
+  local PUBLIC_KEY_NEW_CLUSTER="${20}"
+  local FLEET_REPO_DIR="${22:-"${FLEET_REPO_DIR}"}"
+  local FLEET_REPO_URL="${23:-"${FLEET_REPO_URL}"}"
+  local SW_CATALOGS_REPO_DIR="${24:-"${SW_CATALOGS_REPO_DIR}"}"
+  local SW_CATALOGS_REPO_URL="${25:-"${SW_CATALOGS_REPO_URL}"}"
+  local MGMT_PROJECT_NAME="${27:-"osm_admin"}"
+  local MGMT_CLUSTER_NAME="${28:-"_management"}"
+  local BASE_TEMPLATES_PATH="${29:-"cloud-resources/capi"}"
+  local CAPK_RESOURCES_NAMESPACE="${30:-"default"}"
+
+  create_capi_kubevirt_cluster \
+    "${CLUSTER_KUSTOMIZATION_NAME}" \
+    "${CLUSTER_NAME}" \
+    "${WORKER_MACHINE_COUNT}" \
+    "${CONTROL_PLANE_MACHINE_COUNT}" \
+    "${K8S_VERSION}" \
+    "${_UNUSED_KUBEVIRT_HOST}" \
+    "${_UNUSED_KUBEVIRT_CP_PORT}" \
+    "${_UNUSED_METALLB_SHARED_IP_KEY}" \
+    "${CONTROL_PLANE_CPU_CORES}" \
+    "${CONTROL_PLANE_MEMORY}" \
+    "${CONTROL_PLANE_EPHEMERAL_STORAGE}" \
+    "${WORKER_CPU_CORES}" \
+    "${WORKER_MEMORY}" \
+    "${WORKER_EPHEMERAL_STORAGE}" \
+    "${VM_IMAGE}" \
+    "${POD_CIDR}" \
+    "${SERVICE_CIDR}" \
+    "${CNI}" \
+    "${PUBLIC_KEY_MGMT}" \
+    "${PUBLIC_KEY_NEW_CLUSTER}" \
+    "" \
+    "${FLEET_REPO_DIR}" \
+    "${FLEET_REPO_URL}" \
+    "${SW_CATALOGS_REPO_DIR}" \
+    "${SW_CATALOGS_REPO_URL}" \
+    "true" \
+    "${MGMT_PROJECT_NAME}" \
+    "${MGMT_CLUSTER_NAME}" \
+    "${BASE_TEMPLATES_PATH}" \
+    "${CAPK_RESOURCES_NAMESPACE}"
+}
