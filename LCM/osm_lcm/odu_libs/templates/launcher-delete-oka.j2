apiVersion: argoproj.io/v1alpha1
kind: Workflow
metadata:
  name: {{ workflow_name }}
spec:
  arguments:
    parameters:
    # SW-Catalogs repo
    - name: git_sw_catalogs_url
      value: "{{ git_sw_catalogs_url }}"
    - name: sw_catalogs_destination_folder
      value: "/sw-catalogs/sw-catalogs-osm"
    - name: git_sw_catalogs_cred_secret
      value: sw-catalogs
    # Specific parameters - OKA
    - name: oka_name
      value: "{{ oka_name }}"
    ## Choose among `infra-controllers`, `infra-configs`, `cloud-resources`, `apps`:
    - name: oka_type
      value: "{{ oka_type }}"
    - name: project_name
      value: "{{ osm_project_name }}"
    # Debug/dry run?
    - name: debug
      value: "{{ workflow_debug }}"
    - name: dry_run
      value: "{{ workflow_dry_run }}"

  # Cleanup policy
  ttlStrategy:
    secondsAfterSuccess: 1800     # Time to live after workflow is successful
    secondsAfterFailure: 7200     # Time to live after workflow fails

  workflowTemplateRef:
    name: full-delete-oka-wtf
